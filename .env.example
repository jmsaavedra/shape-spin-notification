# Required: Your wallet private key for signing transactions
PRIVATE_KEY=your_private_key_here

# Optional but HIGHLY RECOMMENDED: Secret for securing cron endpoints
# Generate a strong random string (e.g., using: openssl rand -base64 32)
# Add this to your Vercel environment variables
CRON_SECRET=your_cron_secret_here

# Sendblue API credentials (optional - for iMessage notifications)
# Get these from https://sendblue.com
SENDBLUE_API_KEY=your_sendblue_api_key_here
SENDBLUE_API_SECRET=your_sendblue_api_secret_here

# Phone number to receive notifications (with country code, e.g., +1234567890)
NOTIFICATION_NUMBER=+1234567890
